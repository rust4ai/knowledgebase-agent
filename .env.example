# Neon Postgres
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/knowledgebase?sslmode=require

# DigitalOcean Spaces (S3-compatible)
S3_REGION=nyc3
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx
S3_BUCKET=knowledgebase-docs
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# LLM (for PageIndex indexing + RAG agent)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-5.4

# Server
HOST=0.0.0.0
PORT=3000
